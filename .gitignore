.DS_Store

# 端末ごとに異なる設定ファイル
.config/finicky/finicky.ts

# Codex CLIはファイルのシムリンクに対応していないためフォルダごとシムリンクする
.codex/*
!.codex/config.sync.toml
!.codex/prompts
!.codex/skills
!.codex/AGENTS.md

# Codex は対話セッションでスキルの symlink を辿らないため .config/skills から実体コピーを生成する（deploy.sh）。
# 生成物は追跡せず、Codex 組み込みの .system のみ追跡する。
.codex/skills/*
!.codex/skills/.system
