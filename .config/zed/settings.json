// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "project_panel": {
    "dock": "right",
  },
  "outline_panel": {
    "dock": "right",
  },
  "edit_predictions": {
    "provider": "copilot",
  },
  "git_panel": {
    "dock": "right",
    "tree_view": true,
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "agent_servers": {
    "codex-acp": {
      "default_config_options": {
        "model": "gpt-5.5",
        "mode": "agent-full-access",
        "reasoning_effort": "xhigh"
      },
      "type": "registry",
    },
    "claude-acp": {
      "default_config_options": {
        "effort": "xhigh"
      },
      "favorite_config_option_values": {
        "effort": ["xhigh"],
      },
      "type": "registry",
    },
  },
  "ssh_connections": [
    {
      "host": "ktmm",
      "args": [],
      "projects": [
        {
          "paths": ["/Users/kazukitash"],
        },
        {
          "paths": ["/Users/kazukitash/repo/wklr"],
        },
        {
          "paths": ["/Users/kazukitash/repo/wklr/wklr-mono"],
        },
      ],
    },
  ],
  "indent_guides": {
    "coloring": "indent_aware",
  },
  "minimap": {
    "show": "always",
  },
  "terminal": {
    "max_scroll_history_lines": 100000,
  },
  "auto_update": true,
  "ui_font_weight": 300.0,
  "buffer_font_weight": 300.0,
  "ui_font_features": {
    "calt": 1,
  },
  "buffer_font_features": {
    "calt": 1,
  },
  "buffer_font_family": "Rounded-L Mgen+ 1mn",
  "icon_theme": {
    "mode": "dark",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Mocha",
  },
  "agent": {
    "dock": "left",
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "gpt-5.2-codex",
    },
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-5.2-codex",
    },
    "play_sound_when_agent_done": "always",
    "notify_when_agent_waiting": "all_screens",
    "show_turn_stats": true,
  },
  "file_types": {
    "Dockerfile": ["Dockerfile.*"],
    "Plain Text": ["bun.lock"],
  },
  "telemetry": {
    "metrics": false,
    "diagnostics": false,
  },
  "ui_font_size": 14,
  "buffer_font_size": 12,
  "ui_font_family": "Rounded-L Mgen+ 2cp",
  "theme": {
    "mode": "light",
    "light": "Catppuccin Latte (blue)",
    "dark": "Catppuccin Mocha (blue)",
  },
  "collaboration_panel": {
    "dock": "right",
    "button": false,
  },
  "tab_size": 2,
  "hard_tabs": false,
  "format_on_save": "on",
  "show_whitespaces": "all",
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "languages": {
    "CSS": {
      "formatter": "prettier",
    },
    "Shell Script": {
      "formatter": {
        "external": {
          "command": "shfmt",
          "arguments": [
            "--filename",
            "{buffer_path}",
            "-i",
            "2",
            "-ci",
            "-sr",
            "-bn",
          ],
        },
      },
    },
    "Markdown": {
      "enable_language_server": true,
      "format_on_save": "on",
    },
    "Python": {
      "code_actions_on_format": {
        "source.fixAll.ruff": true,
        "source.organizeImports.ruff": true,
      },
      "tab_size": 4,
    },
    "CSharp": {
      "enable_language_server": true,
      "formatter": "language_server",
    },
    "Rainbow TSV (⭲)": {
      "hard_tabs": true,
    },
  },
  "lsp": {
    "markdownlint": {
      "settings": {
        "MD013": false,
      },
    },
  },
}
